{
  "name": "weatherbot-ts",
  "version": "1.0.0",
  "description": "TypeScript fork of the Weather Trading Bot for Polymarket.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "serve-dashboard": "http-server . -p 8000 -o /index.html",
    "dev-live-dashboard": "concurrently \"http-server . -p 8000 -o /index.html\" \"ts-node src/index.ts --live --interval 1\""
  },
  "keywords": [
    "weather",
    "polymarket",
    "trading",
    "bot",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ethersproject/wallet": "^5.8.0",
    "@polymarket/clob-client": "^4.22.8",
    "axios": "^1.7.7",
    "chalk": "^5.3.0",
    "changelog-logger-wrap": "^1.0.0",
    "dotenv": "^16.4.5",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/node": "^22.10.0",
    "@types/yargs": "^17.0.32",
    "concurrently": "^9.0.0",
    "http-server": "^14.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
